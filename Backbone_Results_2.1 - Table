"""
Q2 Table — Burden concentration summary
=======================================

Purpose:
Prepare a summary table showing how much of the total customer-hour burden
is held by different county groups.

Groups:
    Top 1%
    Top 5%
    Top 10%
    Bottom 50%

Metric:
    customer_hour_burden

Reads:
    Results/Q2/q2_county_burden_by_year.csv

Writes:
    Results/Q2/q2_burden_concentration_summary_table.csv
"""

import os
import numpy as np
import pandas as pd

# ============================================================
# PATHS
# ============================================================

BASE = "/icebox/data/shares/mh1/fgorginpaveh/Project3"
Q2 = f"{BASE}/Power_Outage_ZeroFill/Results/Q2"

COUNTY_CSV = f"{Q2}/q2_county_burden_by_year.csv"
OUT_CSV = f"{Q2}/q2_burden_concentration_summary_table.csv"

# ============================================================
# SETTINGS
# ============================================================

PERIOD = "2015_2025"
BURDEN_COL = "customer_hour_burden"

GROUPS = [
    {
        "County group": "Top 1%",
        "fraction": 0.01,
        "take_top": True,
        "Interpretation": "extreme burden core"
    },
    {
        "County group": "Top 5%",
        "fraction": 0.05,
        "take_top": True,
        "Interpretation": "high-burden counties"
    },
    {
        "County group": "Top 10%",
        "fraction": 0.10,
        "take_top": True,
        "Interpretation": "main concentration group"
    },
    {
        "County group": "Bottom 50%",
        "fraction": 0.50,
        "take_top": False,
        "Interpretation": "low-burden majority"
    },
]

# ============================================================
# LOAD DATA
# ============================================================

county = pd.read_csv(
    COUNTY_CSV,
    dtype={
        "county_fips": str,
        "period": str
    }
)

county["county_fips"] = county["county_fips"].str.zfill(5)
county[BURDEN_COL] = pd.to_numeric(county[BURDEN_COL], errors="coerce").fillna(0)

# Use pooled 2015–2025 data
d = county[county["period"] == PERIOD].copy()

if d.empty:
    raise ValueError(f"No rows found for period = {PERIOD}")

# Sort counties from highest to lowest burden
d = d.sort_values(BURDEN_COL, ascending=False).reset_index(drop=True)

total_burden = d[BURDEN_COL].sum()
n_counties = len(d)

if total_burden == 0:
    raise ValueError("Total customer-hour burden is zero. Cannot calculate shares.")

# ============================================================
# CALCULATE TABLE
# ============================================================

rows = []

for group in GROUPS:
    frac = group["fraction"]
    take_top = group["take_top"]

    n_group = max(1, int(np.ceil(frac * n_counties)))

    if take_top:
        selected = d.head(n_group)
    else:
        selected = d.tail(n_group)

    group_burden = selected[BURDEN_COL].sum()
    share = group_burden / total_burden * 100

    rows.append({
        "County group": group["County group"],
        "Number of counties": n_group,
        "Share of total customer-hours": f"{share:.1f}%",
        "Interpretation": group["Interpretation"]
    })

summary_table = pd.DataFrame(rows)

# ============================================================
# SAVE AND PRINT
# ============================================================

summary_table.to_csv(OUT_CSV, index=False)

print("\nBurden concentration summary")
print("=" * 80)
print(summary_table.to_string(index=False))

print(f"\nSaved table to:")
print(OUT_CSV)
