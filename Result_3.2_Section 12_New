"""
Section 12 figures — normalized vs absolute burden
==================================================
Recomputes R_norm and R_abs from county_risk_input.csv (Section 12 only saved
movers + a text summary), then produces separate figures + a combined panel.

Outputs (Q3_2/figures):
  fig12_scatter_norm_vs_abs.png
  fig12_size_distribution.png
  fig12_movers_map.png
  fig12_urban_bars.png
  fig12_combined_panel.png
"""
import os
import numpy as np
import pandas as pd
import matplotlib
matplotlib.use("Agg")
import matplotlib.pyplot as plt
from scipy.stats import spearmanr
import geopandas as gpd

BASE = "/icebox/data/shares/mh1/fgorginpaveh/Project3"
Q3 = f"{BASE}/Power_Outage_ZeroFill/Results/Q3"
Q3_2 = f"{BASE}/Power_Outage_ZeroFill/Results/Q3_2"
MCC_CSV = f"{BASE}/Power_Outage_ZeroFill/MCC.csv"
FIG_DIR = f"{Q3_2}/figures"
os.makedirs(FIG_DIR, exist_ok=True)
SHP = f"{BASE}/Power_Outage_ZeroFill/RQ2/shapefiles/cb_2022_us_county_5m.shp"
NON_CONUS = {"02", "15", "72", "66", "78", "60", "69"}
MISS = "#bdbdbd"
TOP_FRAC = 0.10


def find(f):
    for b in (Q3_2, Q3):
        if os.path.exists(f"{b}/{f}"):
            return f"{b}/{f}"
    return None


def load_mcc(path):
    m = pd.read_csv(path); m.columns = [c.strip() for c in m.columns]
    fc = "County_FIPS" if "County_FIPS" in m.columns else m.columns[0]
    cc = "Customers" if "Customers" in m.columns else m.columns[1]
    m[cc] = pd.to_numeric(m[cc], errors="coerce")
    fn = pd.to_numeric(m[fc], errors="coerce")
    m = m[fn.notna() & m[cc].notna()]
    return dict(zip(fn[fn.notna()].astype("int64").astype(str).str.zfill(5), m[cc]))


def pctl(s):
    return s.fillna(0).rank(pct=True, method="average") * 100.0


src = find("county_risk_input.csv")
d = pd.read_csv(src, dtype={"county_fips": str})
d["county_fips"] = d["county_fips"].str.zfill(5)
ch = pd.to_numeric(d["total_customer_hours"], errors="coerce")
served = pd.to_numeric(d.get("total_customers_served",
                             d["county_fips"].map(load_mcc(MCC_CSV))), errors="coerce")
served = served.where(served > 0, np.nan)
peak = pd.to_numeric(d["p90_peak_outage"], errors="coerce")
d["E_pct"] = pd.to_numeric(d["E_pct"], errors="coerce").fillna(0)
d["D_pct"] = pd.to_numeric(d["D_pct"], errors="coerce").fillna(0)
n = len(d); k = int(np.ceil(TOP_FRAC * n))

flag = (served < peak).fillna(False)
Bn = (ch / served).replace([np.inf, -np.inf], np.nan)
maxB = Bn[~flag].max(); Bn = Bn.where(~flag, maxB)
d["Bn_pct"] = pctl(Bn); d.loc[flag.values, "Bn_pct"] = 100.0
d["Ba_pct"] = pctl(ch)
d["R_norm"] = d[["E_pct", "Bn_pct", "D_pct"]].mean(axis=1)
d["R_abs"] = d[["E_pct", "Ba_pct", "D_pct"]].mean(axis=1)
d["served"] = served
rho, _ = spearmanr(d["R_norm"], d["R_abs"], nan_policy="omit")
Tn = set(d.nlargest(k, "R_norm")["county_fips"]); Ta = set(d.nlargest(k, "R_abs")["county_fips"])
overlap = len(Tn & Ta) / k
d["top_norm"] = d["county_fips"].isin(Tn); d["top_abs"] = d["county_fips"].isin(Ta)
rho_abs, _ = spearmanr(served, d["R_abs"], nan_policy="omit")
rho_norm, _ = spearmanr(served, d["R_norm"], nan_policy="omit")
print(f"Spearman(norm,abs)={rho:.3f} overlap={overlap*100:.1f}% | "
      f"served~abs={rho_abs:.3f} served~norm={rho_norm:.3f}")

gdf = gpd.read_file(SHP)
gdf["county_fips"] = gdf["GEOID"].astype(str).str.zfill(5)
gdf = gdf[~gdf["county_fips"].str[:2].isin(NON_CONUS)].to_crs("EPSG:5070")
geo = gdf.merge(d, on="county_fips", how="left")


def scatter(ax):
    same = d["top_norm"] == d["top_abs"]
    ax.scatter(d.loc[same, "R_norm"], d.loc[same, "R_abs"], s=10, alpha=0.4,
               color="#9ecae1", edgecolors="none", label="same top-10 status")
    ax.scatter(d.loc[~same, "R_norm"], d.loc[~same, "R_abs"], s=16, alpha=0.85,
               color="#d73027", edgecolors="none", label="changes status")
    ax.plot([0, 100], [0, 100], "k--", lw=1, alpha=0.6)
    ax.set_xlabel("R_norm"); ax.set_ylabel("R_abs")
    ax.set_title(f"Normalized vs absolute\nSpearman={rho:.3f} | overlap={overlap*100:.1f}%")
    ax.legend(fontsize=8, loc="lower right"); ax.set_xlim(-2, 102); ax.set_ylim(-2, 102)


def sizedist(ax):
    sv = d["served"].dropna()
    bins = np.logspace(np.log10(max(1, sv.min())), np.log10(sv.max()), 40)
    ax.hist(d.loc[d["top_norm"], "served"].dropna(), bins=bins, alpha=0.55,
            color="#4575b4", label="top-10% normalized")
    ax.hist(d.loc[d["top_abs"], "served"].dropna(), bins=bins, alpha=0.55,
            color="#d73027", label="top-10% absolute")
    ax.axvline(np.nanmedian(d["served"]), color="k", ls=":", label="all-county median")
    ax.set_xscale("log"); ax.set_xlabel("customers served (log)")
    ax.set_ylabel("counties"); ax.legend(fontsize=8)
    ax.set_title("Who lands in top 10%?\nabsolute skews to larger counties")


def moversmap(ax):
    ta = geo["top_abs"].fillna(False).astype(bool)
    tn = geo["top_norm"].fillna(False).astype(bool)
    geo["mv"] = np.where(ta & ~tn, 2,
                np.where(tn & ~ta, 1,
                np.where(tn & ta, 0, np.nan)))
    geo.plot(column="mv", cmap="coolwarm", vmin=0, vmax=2, linewidth=0.05,
             edgecolor="white", ax=ax, missing_kwds={"color": MISS})
    from matplotlib.patches import Patch
    ax.legend(handles=[Patch(color="#3b4cc0", label="top10 both"),
                       Patch(color="#dddddd", label="only normalized"),
                       Patch(color="#b40426", label="only absolute")],
              loc="lower right", fontsize=8)
    ax.set_axis_off(); ax.set_title("Top-10%: normalized vs absolute burden")


def urbanbars(ax):
    labels = ["corr(size, R_abs)", "corr(size, R_norm)"]
    ax.bar(labels, [rho_abs, rho_norm], color=["#d73027", "#4575b4"])
    for i, v in enumerate([rho_abs, rho_norm]):
        ax.text(i, v + 0.02, f"{v:.3f}", ha="center")
    ax.set_ylim(0, 1); ax.set_ylabel("Spearman with customers_served")
    ax.set_title("Size (urban) dependence\nabsolute higher = urban-dominated")


f, a = plt.subplots(figsize=(8, 7)); scatter(a); f.tight_layout()
f.savefig(f"{FIG_DIR}/fig12_scatter_norm_vs_abs.png", dpi=300); plt.close(f)
f, a = plt.subplots(figsize=(8, 6)); sizedist(a); f.tight_layout()
f.savefig(f"{FIG_DIR}/fig12_size_distribution.png", dpi=300); plt.close(f)
f, a = plt.subplots(figsize=(13, 8)); moversmap(a); f.tight_layout()
f.savefig(f"{FIG_DIR}/fig12_movers_map.png", dpi=300); plt.close(f)
f, a = plt.subplots(figsize=(6, 5)); urbanbars(a); f.tight_layout()
f.savefig(f"{FIG_DIR}/fig12_urban_bars.png", dpi=300); plt.close(f)

fig = plt.figure(figsize=(18, 15))
scatter(fig.add_subplot(2, 2, 1)); sizedist(fig.add_subplot(2, 2, 2))
moversmap(fig.add_subplot(2, 2, 3)); urbanbars(fig.add_subplot(2, 2, 4))
fig.suptitle("Section 12 — normalized vs absolute burden", fontsize=15)
fig.tight_layout(rect=[0, 0, 1, 0.98])
fig.savefig(f"{FIG_DIR}/fig12_combined_panel.png", dpi=300); plt.close(fig)
print(f"wrote 5 figures to {FIG_DIR} (fig12_*)")
