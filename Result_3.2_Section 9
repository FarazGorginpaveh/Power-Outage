"""
Section 9 — Named weight scenarios (transparent, reviewer-friendly)
====================================================================
In addition to the LHS sweep, score every county under four fixed, named
weight vectors over the three main dimensions (E*, B*, D*):

    9.1 equal      R = 1/3 E* + 1/3 B* + 1/3 D*     (== baseline R_base; REFERENCE)
    9.2 exposure   R = 0.50 E* + 0.25 B* + 0.25 D*
    9.3 burden     R = 0.25 E* + 0.50 B* + 0.25 D*
    9.4 recovery   R = 0.25 E* + 0.25 B* + 0.50 D*

For each scenario, compared against the equal-weight score:
    1. Spearman rank correlation
    2. Top-10% overlap  = |T_scn ∩ T_equal| / |T_equal|
    3. Counties newly ENTERING top 10% (in T_scn, not in T_equal)
       and LEAVING top 10% (in T_equal, not in T_scn)

Weights are over E, B, D only (peak excluded), matching the baseline. Because
the equal-weight scenario is proportional to R_base, its ranking is identical
to the baseline, so its own row is the trivial rho=1.0 / overlap=100% check.

Outputs (Q3_2):
    risk_named_weight_scenarios.csv     one row per scenario (rho, overlap,
                                        n_entering, n_leaving, + the weights)
    risk_named_scenario_changes.csv     per-county: which scenarios it enters/
                                        leaves the top 10% in
    figures/fig_named_scenarios_overlap.png   bar chart (rho + overlap)

Reads:  county_risk_input.csv   (E_pct, B_pct, D_pct)   [Q3_2, then Q3]
Requires: pandas, numpy, matplotlib, scipy
"""

import os
import numpy as np
import pandas as pd
import matplotlib

matplotlib.use("Agg")
import matplotlib.pyplot as plt
from scipy.stats import spearmanr

BASE = "/icebox/data/shares/mh1/fgorginpaveh/Project3"
Q3 = f"{BASE}/Power_Outage_ZeroFill/Results/Q3"
Q3_2 = f"{BASE}/Power_Outage_ZeroFill/Results/Q3_2"
OUT_DIR = Q3_2
FIG_DIR = f"{OUT_DIR}/figures"
os.makedirs(FIG_DIR, exist_ok=True)

TOP_FRAC = 0.10

# name -> (wE, wB, wD)
SCENARIOS = {
    "equal":    (1/3, 1/3, 1/3),
    "exposure": (0.50, 0.25, 0.25),
    "burden":   (0.25, 0.50, 0.25),
    "recovery": (0.25, 0.25, 0.50),
}
REFERENCE = "equal"


def find_input(fname):
    for base_dir in (Q3_2, Q3):
        p = f"{base_dir}/{fname}"
        if os.path.exists(p):
            return p
    return None


# ---- load ----
src = find_input("county_risk_input.csv")
if src is None:
    raise FileNotFoundError("county_risk_input.csv not found in Q3_2 or Q3")
print(f"input: {src}")

d = pd.read_csv(src, dtype={"county_fips": str})
d["county_fips"] = d["county_fips"].str.zfill(5)
for c in ["E_pct", "B_pct", "D_pct"]:
    d[c] = pd.to_numeric(d[c], errors="coerce").fillna(0)
n = len(d)
k = int(np.ceil(TOP_FRAC * n))
print(f"counties: {n:,} | top-10% size k = {k:,}")

# ---- score each scenario ----
for name, (wE, wB, wD) in SCENARIOS.items():
    d[f"R_{name}"] = wE * d["E_pct"] + wB * d["B_pct"] + wD * d["D_pct"]

# reference top-10% set
ref_top = set(d.nlargest(k, f"R_{REFERENCE}")["county_fips"])

# ---- per-scenario metrics ----
rows = []
change_records = []   # per-county entering/leaving detail
for name, (wE, wB, wD) in SCENARIOS.items():
    score = d[f"R_{name}"]
    rho, pval = spearmanr(score, d[f"R_{REFERENCE}"], nan_policy="omit")
    scn_top = set(d.nlargest(k, f"R_{name}")["county_fips"])

    overlap_n = len(scn_top & ref_top)
    overlap_pct = overlap_n / k
    entering = scn_top - ref_top          # newly in top 10% under this scenario
    leaving = ref_top - scn_top           # dropped out of top 10%

    rows.append({
        "scenario": name,
        "w_E": round(wE, 4), "w_B": round(wB, 4), "w_D": round(wD, 4),
        "spearman_vs_equal": round(rho, 4),
        "p_value": f"{pval:.2e}",
        "top10_overlap_n": overlap_n,
        "top10_size_k": k,
        "top10_overlap_pct": round(overlap_pct * 100, 1),
        "n_entering_top10": len(entering),
        "n_leaving_top10": len(leaving),
    })

    for f in entering:
        change_records.append({"scenario": name, "county_fips": f,
                               "change": "entered_top10"})
    for f in leaving:
        change_records.append({"scenario": name, "county_fips": f,
                               "change": "left_top10"})

summary = pd.DataFrame(rows)
summary.to_csv(f"{OUT_DIR}/risk_named_weight_scenarios.csv", index=False)

# ---- per-county change detail (with names) ----
changes = pd.DataFrame(change_records)
if len(changes):
    changes = changes.merge(
        d[["county_fips", "county_name", "state",
           "E_pct", "B_pct", "D_pct"]], on="county_fips", how="left")
    changes = changes.sort_values(["scenario", "change", "county_fips"])
changes.to_csv(f"{OUT_DIR}/risk_named_scenario_changes.csv", index=False)

print("\nNamed-scenario summary (vs equal-weight):")
print(summary.to_string(index=False))
print(f"\nWrote:\n  {OUT_DIR}/risk_named_weight_scenarios.csv")
print(f"  {OUT_DIR}/risk_named_scenario_changes.csv  ({len(changes):,} rows)")

# ---- figure: rho + overlap per scenario ----
plot = summary[summary["scenario"] != REFERENCE]
fig, ax1 = plt.subplots(figsize=(8, 5))
x = np.arange(len(plot))
b1 = ax1.bar(x - 0.2, plot["spearman_vs_equal"], width=0.4,
             color="#4575b4", label="Spearman vs equal")
ax1.set_ylabel("Spearman rho", color="#4575b4")
ax1.set_ylim(0, 1.02)
ax1.tick_params(axis="y", labelcolor="#4575b4")
ax2 = ax1.twinx()
b2 = ax2.bar(x + 0.2, plot["top10_overlap_pct"], width=0.4,
             color="#d73027", label="Top-10% overlap %")
ax2.set_ylabel("Top-10% overlap (%)", color="#d73027")
ax2.set_ylim(0, 102)
ax2.tick_params(axis="y", labelcolor="#d73027")
ax1.set_xticks(x)
ax1.set_xticklabels(plot["scenario"])
ax1.set_title("Named weight scenarios vs equal-weight baseline\n"
              "(agreement with the transparent equal-weight ranking)")
for b in b1:
    ax1.text(b.get_x() + b.get_width()/2, b.get_height() + 0.01,
             f"{b.get_height():.3f}", ha="center", va="bottom", fontsize=8)
for b in b2:
    ax2.text(b.get_x() + b.get_width()/2, b.get_height() + 1,
             f"{b.get_height():.0f}%", ha="center", va="bottom", fontsize=8)
fig.tight_layout()
fig.savefig(f"{FIG_DIR}/fig_named_scenarios_overlap.png", dpi=300)
plt.close(fig)
print(f"  {FIG_DIR}/fig_named_scenarios_overlap.png")
