"""
Section 12 — Absolute vs normalized burden sensitivity
=======================================================
Normalized burden divides customer-hours by customers served, so reviewers may
ask whether the ranking changes if raw (absolute) burden is used instead. Build
two scores that differ ONLY in the burden term (exposure E* and recovery D* are
identical in both):

    B_norm* = Pctl( customer_hours / customers_served )   [cap1 fixed: sat=max]
    B_abs*  = Pctl( customer_hours )                        (no denominator)

    R_norm = (E* + B_norm* + D*) / 3
    R_abs  = (E* + B_abs*  + D*) / 3

Compare:
    1. Spearman(R_norm, R_abs)
    2. Top-10% overlap
    3. Geographic changes (counties entering/leaving top 10%, by state)
    4. Do urban / large counties dominate the ABSOLUTE score?
       Tested with customers_served as a size proxy:
         - Spearman(customers_served, R_abs) vs Spearman(customers_served, R_norm)
         - median customers_served in the two top-10% sets vs all counties

Output (Q3_2):
    risk_burden_normalization_sensitivity.csv   summary + urban-domination metrics
    risk_burden_norm_changes.csv                per-county enter/leave detail
    figures/fig_burden_norm_vs_abs.png          scatter + size-distribution panel

Reads:  county_risk_input.csv   (E_pct, D_pct, total_customer_hours,
        total_customers_served, p90_peak_outage)    [Q3_2, then Q3]
Requires: pandas, numpy, matplotlib, scipy
"""

import os
import numpy as np
import pandas as pd
import matplotlib

matplotlib.use("Agg")
import matplotlib.pyplot as plt
from scipy.stats import spearmanr

BASE = "/icebox/data/shares/mh1/fgorginpaveh/Project3"
Q3 = f"{BASE}/Power_Outage_ZeroFill/Results/Q3"
Q3_2 = f"{BASE}/Power_Outage_ZeroFill/Results/Q3_2"
OUT_DIR = Q3_2
FIG_DIR = f"{OUT_DIR}/figures"
os.makedirs(FIG_DIR, exist_ok=True)

TOP_FRAC = 0.10


def find_input(fname):
    for base_dir in (Q3_2, Q3):
        p = f"{base_dir}/{fname}"
        if os.path.exists(p):
            return p
    return None


def pctl(s):
    return s.fillna(0).rank(pct=True, method="average") * 100.0


# ---- load ----
src = find_input("county_risk_input.csv")
if src is None:
    raise FileNotFoundError("county_risk_input.csv not found in Q3_2 or Q3")
print(f"input: {src}")

d = pd.read_csv(src, dtype={"county_fips": str})
d["county_fips"] = d["county_fips"].str.zfill(5)
ch = pd.to_numeric(d["total_customer_hours"], errors="coerce")
served = pd.to_numeric(d["total_customers_served"], errors="coerce")
served = served.where(served > 0, np.nan)
peak = pd.to_numeric(d["p90_peak_outage"], errors="coerce")
d["E_pct"] = pd.to_numeric(d["E_pct"], errors="coerce").fillna(0)
d["D_pct"] = pd.to_numeric(d["D_pct"], errors="coerce").fillna(0)
n = len(d)
k = int(np.ceil(TOP_FRAC * n))
print(f"counties: {n:,} | top-10% size k = {k:,}")

# ---- two burden variants ----
flag = (served < peak).fillna(False)               # out > served (data limitation)
B_norm = (ch / served).replace([np.inf, -np.inf], np.nan)
maxB = B_norm[~flag].max()
B_norm = B_norm.where(~flag, maxB)                 # saturated -> max, not 1.0
d["B_norm_pct"] = pctl(B_norm)
d.loc[flag.values, "B_norm_pct"] = 100.0
d["B_abs_pct"] = pctl(ch)

d["R_norm"] = d[["E_pct", "B_norm_pct", "D_pct"]].mean(axis=1)
d["R_abs"] = d[["E_pct", "B_abs_pct", "D_pct"]].mean(axis=1)

# ---- 1. Spearman ----
rho, pval = spearmanr(d["R_norm"], d["R_abs"], nan_policy="omit")

# ---- 2. top-10% overlap ----
T_norm = set(d.nlargest(k, "R_norm")["county_fips"])
T_abs = set(d.nlargest(k, "R_abs")["county_fips"])
overlap_n = len(T_norm & T_abs)
overlap_pct = overlap_n / k
entering_abs = T_abs - T_norm     # appear in top10 only when absolute burden used
leaving_norm = T_norm - T_abs     # in top10 under normalized, drop out under absolute

# ---- 4. urban / size domination test ----
d["top_norm"] = d["county_fips"].isin(T_norm)
d["top_abs"] = d["county_fips"].isin(T_abs)
rho_size_abs, _ = spearmanr(served, d["R_abs"], nan_policy="omit")
rho_size_norm, _ = spearmanr(served, d["R_norm"], nan_policy="omit")
med_all = np.nanmedian(served)
med_abs = np.nanmedian(served[d["top_abs"].values])
med_norm = np.nanmedian(served[d["top_norm"].values])

# interpretation
if rho_size_abs >= 0.5 and rho_size_abs - rho_size_norm >= 0.25:
    urban_note = ("absolute-burden score is strongly size-driven: large "
                  "(urban) counties dominate it, which normalization removes")
elif rho_size_abs - rho_size_norm >= 0.10:
    urban_note = ("absolute burden is moderately size-driven; normalization "
                  "reduces the pull of large counties")
else:
    urban_note = ("absolute burden is not strongly size-driven here; "
                  "normalization changes little on the size axis")

if rho >= 0.90 and overlap_pct >= 0.80:
    rank_note = "rankings largely agree; normalization mainly aids interpretability"
elif rho >= 0.70:
    rank_note = "rankings partly diverge; burden definition matters for hotspots"
else:
    rank_note = "rankings diverge substantially; burden definition is decisive"

# ---- summary CSV ----
summary = pd.DataFrame([
    {"Metric": "Spearman R_norm vs R_abs",
     "Value": f"{rho:.4f}  (p = {pval:.2e})"},
    {"Metric": "Top 10% overlap",
     "Value": f"{overlap_n:,} / {k:,}  ({overlap_pct*100:.1f}%)"},
    {"Metric": "Counties entering top 10% under ABSOLUTE burden",
     "Value": str(len(entering_abs))},
    {"Metric": "Counties leaving top 10% under ABSOLUTE burden",
     "Value": str(len(leaving_norm))},
    {"Metric": "Spearman customers_served vs R_abs",
     "Value": f"{rho_size_abs:.4f}"},
    {"Metric": "Spearman customers_served vs R_norm",
     "Value": f"{rho_size_norm:.4f}"},
    {"Metric": "Median customers_served: all counties",
     "Value": f"{med_all:,.0f}"},
    {"Metric": "Median customers_served: top-10% ABSOLUTE",
     "Value": f"{med_abs:,.0f}"},
    {"Metric": "Median customers_served: top-10% NORMALIZED",
     "Value": f"{med_norm:,.0f}"},
    {"Metric": "Urban-domination interpretation", "Value": urban_note},
    {"Metric": "Ranking interpretation", "Value": rank_note},
])
summary.to_csv(f"{OUT_DIR}/risk_burden_normalization_sensitivity.csv", index=False)
print("\nBurden normalization sensitivity summary:")
print(summary.to_string(index=False))

# ---- 3. geographic changes (by state) ----
d["served"] = served
chg = d[d["top_norm"] != d["top_abs"]][
    ["county_fips", "county_name", "state", "served",
     "total_customer_hours", "B_norm_pct", "B_abs_pct",
     "R_norm", "R_abs", "top_norm", "top_abs"]].copy()
chg["change"] = np.where(chg["top_abs"] & ~chg["top_norm"],
                         "enters_top10_under_absolute",
                         "leaves_top10_under_absolute")
chg = chg.sort_values(["change", "state", "county_fips"])
chg.to_csv(f"{OUT_DIR}/risk_burden_norm_changes.csv", index=False)

by_state = (chg.groupby(["change", "state"]).size()
              .rename("n").reset_index()
              .sort_values(["change", "n"], ascending=[True, False]))
print("\nTop states gaining top-10% slots under ABSOLUTE burden:")
gain = by_state[by_state["change"] == "enters_top10_under_absolute"].head(8)
print(gain.to_string(index=False) if len(gain) else "  (none)")

# ---- figure ----
fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(15, 6.5))

# (a) R_norm vs R_abs scatter, movers highlighted
same = d["top_norm"] == d["top_abs"]
ax1.scatter(d.loc[same, "R_norm"], d.loc[same, "R_abs"], s=10, alpha=0.4,
            color="#9ecae1", edgecolors="none", label="same top-10 status")
ax1.scatter(d.loc[~same, "R_norm"], d.loc[~same, "R_abs"], s=16, alpha=0.8,
            color="#d73027", edgecolors="none", label="changes top-10 status")
ax1.plot([0, 100], [0, 100], ls="--", lw=1, color="black", alpha=0.6)
ax1.set_xlabel("R_norm (normalized burden)")
ax1.set_ylabel("R_abs (absolute burden)")
ax1.set_title(f"Normalized vs absolute burden risk\n"
              f"Spearman = {rho:.3f} | top-10% overlap = {overlap_pct*100:.1f}%")
ax1.legend(loc="lower right", fontsize=8)
ax1.set_xlim(-2, 102)
ax1.set_ylim(-2, 102)

# (b) size distribution of the two top-10% sets (log x)
bins = np.logspace(np.log10(max(1, np.nanmin(served))),
                   np.log10(np.nanmax(served)), 40)
ax2.hist(served[d["top_norm"].values].dropna(), bins=bins, alpha=0.55,
         color="#4575b4", label="top-10% normalized")
ax2.hist(served[d["top_abs"].values].dropna(), bins=bins, alpha=0.55,
         color="#d73027", label="top-10% absolute")
ax2.axvline(med_all, color="black", ls=":", lw=1, label=f"all-county median")
ax2.set_xscale("log")
ax2.set_xlabel("customers served (log scale) — county size proxy")
ax2.set_ylabel("number of counties")
ax2.set_title("Who lands in the top 10%?\n"
              "Absolute burden skews toward larger (urban) counties")
ax2.legend(fontsize=8)
fig.tight_layout()
fig.savefig(f"{FIG_DIR}/fig_burden_norm_vs_abs.png", dpi=300)
plt.close(fig)

print(f"\nWrote:\n  {OUT_DIR}/risk_burden_normalization_sensitivity.csv")
print(f"  {OUT_DIR}/risk_burden_norm_changes.csv  ({len(chg):,} movers)")
print(f"  {FIG_DIR}/fig_burden_norm_vs_abs.png")
